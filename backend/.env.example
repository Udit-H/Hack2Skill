# Sahayak Backend Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# CORS Configuration — Comma-separated list of allowed origins
# ============================================================================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# For production, use:
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# LLM Configuration (AWS Bedrock)
# ============================================================================
LLM_PROVIDER=bedrock
LLM_MODEL_ID=us.meta.llama3-2-90b-instruct-v1:0

# Available Llama models on Bedrock:
# - us.meta.llama3-2-1b-instruct-v1:0 (1B parameters)
# - us.meta.llama3-2-3b-instruct-v1:0 (3B parameters)
# - us.meta.llama3-2-11b-instruct-v1:0 (11B parameters)
# - us.meta.llama3-2-90b-instruct-v1:0 (90B parameters)
# - meta.llama3-1-8b-instruct-v1:0 (8B parameters)
# - meta.llama3-1-70b-instruct-v1:0 (70B parameters)

# Legacy Gemini support (set LLM_PROVIDER=openai)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ============================================================================
# AWS Configuration (for Bedrock LLM, Textract OCR, and S3)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=your_s3_bucket_name

# ============================================================================
# Azure Document Intelligence (fallback option)
# ============================================================================
DOCUMENT_INTELLIGENCE_API_KEY=your_azure_api_key
DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# ============================================================================
# Redis Configuration (for memory storage)
# ============================================================================
REDIS_HOST=localhost
REDIS_PASSWORD=
REDIS_DB_NAME=0

# ============================================================================
# Rate Limiting
# Current limits:
# - Session creation: 10 requests/minute per IP
# - Get session: 30 requests/minute per IP
# - Chat: 20 requests/minute per IP
# - Upload: 5 requests/minute per IP
# - Panic wipe: 1 request/minute per IP
# - Health check: 60 requests/minute per IP
# ============================================================================
