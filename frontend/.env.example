# Amazon Cognito Configuration
# Get these from: AWS Console > Cognito > User pools > Your User Pool > App integration

VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=your_client_id_here
VITE_COGNITO_REGION=us-east-1

# Backend API base URL for production (Amplify)
# Example: https://api.yourdomain.com
VITE_API_BASE_URL=

# Local dev note:
# Vite proxy in vite.config.js routes /api -> http://localhost:8000
